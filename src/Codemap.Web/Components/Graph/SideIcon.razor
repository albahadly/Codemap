@* Tiny inline-SVG icon set for the sidebar — hand-rolled, no icon library (spec §2). *@
<svg class="side-icon @Class" viewBox="0 0 16 16" fill="none" stroke="currentColor"
     stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    @switch (Name)
    {
        case "scan": // package/cube — an in-memory scan result
            <path d="M8 1.75 13.75 5v6L8 14.25 2.25 11V5L8 1.75z" />
            <path d="M2.25 5 8 8.25 13.75 5" />
            <path d="M8 8.25v6" />
            break;
        case "snapshot": // database cylinder — a published snapshot
            <ellipse cx="8" cy="3.75" rx="5.25" ry="1.9" />
            <path d="M2.75 3.75v8.5c0 1.05 2.35 1.9 5.25 1.9s5.25-.85 5.25-1.9v-8.5" />
            <path d="M2.75 8c0 1.05 2.35 1.9 5.25 1.9S13.25 9.05 13.25 8" />
            break;
        case "folder": // namespace group with children
            <path d="M1.75 4.5c0-.55.45-1 1-1h3.2l1.55 1.75h6.75c.55 0 1 .45 1 1v6c0 .55-.45 1-1 1H2.75c-.55 0-1-.45-1-1v-7.75z" />
            break;
        case "namespace": // leaf namespace — braces
            <path d="M6 2.5c-1.4 0-1.9.7-1.9 1.9v1.7c0 .95-.5 1.4-1.6 1.9 1.1.5 1.6.95 1.6 1.9v1.7c0 1.2.5 1.9 1.9 1.9" />
            <path d="M10 2.5c1.4 0 1.9.7 1.9 1.9v1.7c0 .95.5 1.4 1.6 1.9-1.1.5-1.6.95-1.6 1.9v1.7c0 1.2-.5 1.9-1.9 1.9" />
            break;
        case "all": // grid — "(all namespaces)"
            <rect x="2" y="2" width="5" height="5" rx="1" />
            <rect x="9" y="2" width="5" height="5" rx="1" />
            <rect x="2" y="9" width="5" height="5" rx="1" />
            <rect x="9" y="9" width="5" height="5" rx="1" />
            break;
        case "csharp": // C# language badge
            <rect x="0.75" y="2.5" width="14.5" height="11" rx="2.5" fill="currentColor" opacity="0.16" stroke="none" />
            @BadgeText("C#")
            break;
        case "js": // JavaScript/TypeScript language badge
            <rect x="0.75" y="2.5" width="14.5" height="11" rx="2.5" fill="currentColor" opacity="0.16" stroke="none" />
            @BadgeText("JS")
            break;
        case "sun": // light mode
            <circle cx="8" cy="8" r="3.1" />
            <path d="M8 1.25v1.9M8 12.85v1.9M1.25 8h1.9M12.85 8h1.9M3.2 3.2l1.35 1.35M11.45 11.45l1.35 1.35M12.8 3.2l-1.35 1.35M4.55 11.45 3.2 12.8" />
            break;
        case "moon": // dark mode
            <path d="M13.6 10.1A6.1 6.1 0 1 1 5.9 2.4a5.05 5.05 0 0 0 7.7 7.7z" />
            break;
    }
</svg>

@code {
    [Parameter] public required string Name { get; set; }
    [Parameter] public string? Class { get; set; }

    // Razor reserves the <text> tag, so SVG text is emitted as raw markup (label is a hardcoded literal).
    private static MarkupString BadgeText(string label) => (MarkupString)
        $"""<text x="8" y="10.9" text-anchor="middle" font-size="7.6" font-weight="700" fill="currentColor" stroke="none" style="font-family: var(--font-mono)">{label}</text>""";
}
