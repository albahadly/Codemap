@using System.Globalization
@inject IJSRuntime JS
@inject ILogger<GraphCanvas> Logger
@implements IAsyncDisposable

<div class="canvas-wrap">
    <div class="filter-pills" title="Language filter (1 / 2 / 3)">
        <button class="@(Filter == LanguageFilter.All ? "active" : null)" @onclick="() => SetFilter(LanguageFilter.All)">All</button>
        <button class="@(Filter == LanguageFilter.CSharp ? "active" : null)" @onclick="() => SetFilter(LanguageFilter.CSharp)">C#</button>
        <button class="@(Filter == LanguageFilter.Js ? "active" : null)" @onclick="() => SetFilter(LanguageFilter.Js)">JS</button>
    </div>
    @if (Graph is not null && Filter != LanguageFilter.All)
    {
        <div class="filter-count">showing @VisibleNodes().Count of @Graph.Nodes.Count types</div>
    }

    <div class="canvas-toolbar">
        <button aria-label="Zoom in" title="Zoom in (+)" @onclick="ZoomInAsync">+</button>
        <button aria-label="Zoom out" title="Zoom out (-)" @onclick="ZoomOutAsync">−</button>
        <button aria-label="Zoom to fit" title="Zoom to fit (F)" @onclick="ZoomToFitAsync">⤢</button>
        <button aria-label="Arrange nodes" title="Arrange nodes (auto layout)" @onclick="Arrange">⊞</button>
    </div>

    @if (Graph is null || Graph.Nodes.Count == 0)
    {
        <div class="canvas-empty">
            <div class="big">Scan a repository to see its structure</div>
            <ol class="quick-start">
                <li><span class="step">1</span> Paste a path to a solution or project folder in the box above</li>
                <li><span class="step">2</span> Press <b>Analyze</b> (or <kbd>Ctrl</kbd>+<kbd>Enter</kbd>) and watch the progress bar</li>
                <li><span class="step">3</span> Click any node to inspect it — linked nodes light up automatically</li>
            </ol>
            <div class="empty-hints">
                <span><kbd>Ctrl</kbd>+<kbd>K</kbd> find a type</span>
                <span><kbd>F</kbd> fit to view</span>
                <span><kbd>?</kbd> all shortcuts</span>
            </div>
        </div>
    }

    @* Pan/zoom/drag/selection-highlight are handled entirely client-side (codemap.canvas in
       codemap.js) — no Blazor pointer events here, so mouse moves never round-trip to the server.
       The .viewport transform and selection classes are owned by JS; keep them out of this markup. *@
    <svg class="graph-svg" @ref="_svgElement">
        <defs>
            @* arrow fills come from app.css so they follow the active theme *@
            <marker id="arr-inherits" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
                <path d="M0,0 L10,5 L0,10 z" />
            </marker>
            <marker id="arr-implements" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
                <path d="M0,0 L10,5 L0,10 z" />
            </marker>
            <marker id="arr-calls" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
                <path d="M0,0 L10,5 L0,10 z" />
            </marker>
            <marker id="arr-references" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
                <path d="M0,0 L10,5 L0,10 z" />
            </marker>
            <marker id="arr-invokes" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
                <path d="M0,0 L10,5 L0,10 z" />
            </marker>
        </defs>
        <g class="viewport">
            @foreach (var edge in VisibleEdges())
            {
                var kindClass = edge.Kind.ToString().ToLowerInvariant();
                <path class="edge-path @kindClass"
                      d="@EdgePath(edge)"
                      data-from="@edge.FromId" data-to="@edge.ToId"
                      marker-end="url(#arr-@kindClass)" />
            }
            @foreach (var node in VisibleNodes())
            {
                var pos = PositionOf(node.Id);
                var classes = $"node-card {LangClass(node.Language)}"
                              + (DiffAddedIds?.Contains(node.Id) == true ? " diff-added" : "")
                              + (DiffChangedIds?.Contains(node.Id) == true ? " diff-changed" : "");
                <g class="@classes" transform="translate(@Inv(pos.X) @Inv(pos.Y))"
                   data-node-id="@node.Id" @key="node.Id">
                    <title>@node.DisplayName — @node.Kind (@LangBadge(node.Language))&#10;@(string.IsNullOrEmpty(node.Namespace) ? "(global)" : node.Namespace)&#10;@node.SourceFile</title>
                    <rect class="box" width="@Inv(NodeWidth)" height="@Inv(NodeHeight)" rx="10" />
                    <rect class="accent @KindCss(node.Kind)" width="3.5" height="@Inv(NodeHeight)" rx="1.5" />
                    <text class="name" x="13" y="21">@Truncate(node.DisplayName, 21)</text>
                    <text class="meta" x="13" y="37">@node.Kind</text>
                    <text class="ns" x="13" y="53">@Truncate(node.Namespace, 30)</text>
                    <rect class="lang-chip @LangClass(node.Language)" x="@Inv(NodeWidth - 33)" y="7" width="25" height="14" rx="3.5" />
                    <text class="lang-chip-text @LangClass(node.Language)" x="@Inv(NodeWidth - 20.5)" y="17.5" text-anchor="middle">@LangBadge(node.Language)</text>
                    @if (Annotations is not null && Annotations.ContainsKey(node.Id))
                    {
                        <circle class="annot" cx="@Inv(NodeWidth - 42)" cy="14" r="3.5" />
                    }
                </g>
            }
        </g>
    </svg>
</div>

@code {
    // Mirrored in codemap.js (canvas nodeW/nodeH defaults) — passed to attach() so JS edge
    // routing matches EdgePath below.
    private const double NodeWidth = 190;
    private const double NodeHeight = 64;

    [Parameter] public TopologyGraph? Graph { get; set; }
    [Parameter] public string? SelectedNodeId { get; set; }
    [Parameter] public LanguageFilter Filter { get; set; }
    [Parameter] public EventCallback<LanguageFilter> FilterChanged { get; set; }
    [Parameter] public EventCallback<string?> NodeSelected { get; set; }
    [Parameter] public IReadOnlySet<string>? DiffAddedIds { get; set; }
    [Parameter] public IReadOnlySet<string>? DiffChangedIds { get; set; }
    [Parameter] public IReadOnlyDictionary<string, string>? Annotations { get; set; }

    private readonly Dictionary<string, (double X, double Y)> _positions = new(StringComparer.Ordinal);
    private ElementReference _svgElement;
    private DotNetObjectReference<GraphCanvas>? _selfRef;
    private Guid _laidOutGraphId;
    private bool _attached;
    private bool _shouldRender = true;
    private bool _syncQueued;
    private bool _fitQueued;

    // Snapshot of the parameters the canvas markup actually depends on. Rendering a huge graph is
    // expensive even when the diff is empty, so parent renders that change nothing (toasts, scan
    // progress) or change only the selection (a client-side visual) skip re-rendering entirely.
    private TopologyGraph? _renderedGraph;
    private LanguageFilter _renderedFilter;
    private IReadOnlySet<string>? _renderedDiffAdded;
    private IReadOnlySet<string>? _renderedDiffChanged;
    private int _renderedAnnotationCount;
    private string? _appliedSelectedId;

    private List<CodeNode>? _visibleNodes;
    private List<CodeEdge>? _visibleEdges;

    private static string Inv(double value) => value.ToString("0.##", CultureInfo.InvariantCulture);

    protected override void OnParametersSet()
    {
        var structureChanged =
            !ReferenceEquals(Graph, _renderedGraph)
            || Filter != _renderedFilter
            || !ReferenceEquals(DiffAddedIds, _renderedDiffAdded)
            || !ReferenceEquals(DiffChangedIds, _renderedDiffChanged)
            // Annotations is mutated in place by the parent, so count is the change signal; a
            // value-only edit (same keys) doesn't affect canvas markup.
            || (Annotations?.Count ?? 0) != _renderedAnnotationCount;

        if (structureChanged)
        {
            _renderedGraph = Graph;
            _renderedFilter = Filter;
            _renderedDiffAdded = DiffAddedIds;
            _renderedDiffChanged = DiffChangedIds;
            _renderedAnnotationCount = Annotations?.Count ?? 0;
            _visibleNodes = null;
            _visibleEdges = null;
            _shouldRender = true;
            _syncQueued = true;

            if (Graph is not null && Graph.Id != _laidOutGraphId)
            {
                _laidOutGraphId = Graph.Id;
                ComputeLayout();
                _fitQueued = true;
            }
        }

        if (_appliedSelectedId != SelectedNodeId)
        {
            _appliedSelectedId = SelectedNodeId;
            // Selection came from outside the canvas (quick-jump, Esc, relation click) — apply the
            // highlight client-side without re-rendering. When a sync is queued it re-applies anyway.
            if (_attached && !_syncQueued) _ = ApplySelectionAsync(SelectedNodeId);
        }
    }

    protected override bool ShouldRender() => _shouldRender;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
            await CanvasJsAsync("codemap.canvas.attach", _svgElement, _selfRef, NodeWidth, NodeHeight);
            _attached = true;
        }
        if (_syncQueued)
        {
            _syncQueued = false;
            var fit = _fitQueued;
            _fitQueued = false;
            await CanvasJsAsync("codemap.canvas.sync", fit, _appliedSelectedId);
        }
        _shouldRender = false;
    }

    /// All canvas interop funnels through here: a failed call (circuit tearing down, or a stale
    /// tab whose cached codemap.js predates the canvas module) must never fault the circuit.
    private async Task CanvasJsAsync(string identifier, params object?[] args)
    {
        try { await JS.InvokeVoidAsync(identifier, args); }
        catch (JSDisconnectedException) { /* circuit gone */ }
        catch (JSException ex)
        {
            Logger.LogWarning(ex, "Canvas interop call {Identifier} failed (stale client script?).", identifier);
        }
    }

    private Task ApplySelectionAsync(string? nodeId) => CanvasJsAsync("codemap.canvas.select", nodeId);

    // ── JS callbacks (client canvas → server state) ───────────────────────────────

    [JSInvokable]
    public Task OnNodeSelectedJs(string? nodeId)
    {
        _appliedSelectedId = nodeId; // JS already applied the highlight
        return NodeSelected.InvokeAsync(nodeId);
    }

    [JSInvokable]
    public void OnNodeMovedJs(string nodeId, double x, double y) => _positions[nodeId] = (x, y);

    // ── visibility ────────────────────────────────────────────────────────────────

    private List<CodeNode> VisibleNodes() =>
        _visibleNodes ??= Graph is null
            ? []
            : Graph.Nodes.Where(n => Filter.Matches(n.Language)).ToList();

    private List<CodeEdge> VisibleEdges()
    {
        if (_visibleEdges is null)
        {
            if (Graph is null)
            {
                _visibleEdges = [];
            }
            else
            {
                var visible = VisibleNodes().Select(n => n.Id).ToHashSet(StringComparer.Ordinal);
                _visibleEdges = Graph.Edges
                    .Where(e => visible.Contains(e.FromId) && visible.Contains(e.ToId))
                    .ToList();
            }
        }
        return _visibleEdges;
    }

    private static string LangClass(Language language) =>
        language == Language.CSharp ? "cs" : "js";

    private static string LangBadge(Language language) => language switch
    {
        Language.CSharp => "C#",
        Language.TypeScript => "TS",
        _ => "JS",
    };

    private static string KindCss(TypeKind kind) => "kind-" + kind.ToString().ToLowerInvariant();

    private static string Truncate(string value, int max) =>
        string.IsNullOrEmpty(value) ? "—" : value.Length <= max ? value : value[..(max - 1)] + "…";

    // ── layout ────────────────────────────────────────────────────────────────────

    /// Deterministic namespace-cluster layout: nodes grouped by namespace, each cluster a small grid,
    /// clusters flowed into rows. Users refine by dragging; positions persist per graph while loaded.
    private void ComputeLayout()
    {
        _positions.Clear();
        if (Graph is null) return;

        const double cardGapX = 26, cardGapY = 20, clusterGap = 70;
        var groups = Graph.Nodes
            .GroupBy(n => n.Namespace)
            .OrderBy(g => g.Key, StringComparer.OrdinalIgnoreCase)
            .ToList();

        double cursorX = 0, cursorY = 0, rowMaxHeight = 0;
        var targetRowWidth = Math.Max(1600, Math.Sqrt(Graph.Nodes.Count) * (NodeWidth + cardGapX) * 1.4);

        foreach (var group in groups)
        {
            var nodes = group.OrderBy(n => n.Kind).ThenBy(n => n.DisplayName, StringComparer.OrdinalIgnoreCase).ToList();
            var cols = Math.Clamp((int)Math.Ceiling(Math.Sqrt(nodes.Count)), 1, 4);
            var rows = (int)Math.Ceiling(nodes.Count / (double)cols);
            var clusterWidth = cols * (NodeWidth + cardGapX);
            var clusterHeight = rows * (NodeHeight + cardGapY);

            if (cursorX > 0 && cursorX + clusterWidth > targetRowWidth)
            {
                cursorX = 0;
                cursorY += rowMaxHeight + clusterGap;
                rowMaxHeight = 0;
            }

            for (var i = 0; i < nodes.Count; i++)
            {
                var col = i % cols;
                var row = i / cols;
                _positions[nodes[i].Id] = (cursorX + col * (NodeWidth + cardGapX), cursorY + row * (NodeHeight + cardGapY));
            }

            cursorX += clusterWidth + clusterGap;
            rowMaxHeight = Math.Max(rowMaxHeight, clusterHeight);
        }
    }

    private (double X, double Y) PositionOf(string nodeId)
    {
        if (!_positions.TryGetValue(nodeId, out var pos))
            _positions[nodeId] = pos = (0, 0);
        return pos;
    }

    // Mirrored in codemap.js (canvas edgePathD) so edges follow nodes live while dragging —
    // keep the two in sync.
    private string EdgePath(CodeEdge edge)
    {
        var s = PositionOf(edge.FromId);
        var t = PositionOf(edge.ToId);
        var leftToRight = t.X + NodeWidth / 2 >= s.X + NodeWidth / 2;

        var (sx, sy) = leftToRight ? (s.X + NodeWidth, s.Y + NodeHeight / 2) : (s.X, s.Y + NodeHeight / 2);
        var (tx, ty) = leftToRight ? (t.X, t.Y + NodeHeight / 2) : (t.X + NodeWidth, t.Y + NodeHeight / 2);
        var bend = Math.Max(42, Math.Abs(tx - sx) / 2);
        var sign = leftToRight ? 1 : -1;

        return $"M {Inv(sx)} {Inv(sy)} C {Inv(sx + sign * bend)} {Inv(sy)}, {Inv(tx - sign * bend)} {Inv(ty)}, {Inv(tx)} {Inv(ty)}";
    }

    // ── interaction (discrete actions only; continuous input lives in codemap.js) ──

    private Task SetFilter(LanguageFilter filter) => FilterChanged.InvokeAsync(filter);

    public Task ZoomInAsync() => CanvasJsAsync("codemap.canvas.zoomIn");
    public Task ZoomOutAsync() => CanvasJsAsync("codemap.canvas.zoomOut");
    public Task ZoomToFitAsync() => CanvasJsAsync("codemap.canvas.zoomToFit");
    public Task CenterOnNodeAsync(string nodeId) => CanvasJsAsync("codemap.canvas.centerOnNode", nodeId);

    /// Re-runs the namespace-cluster auto layout (undoes manual dragging) and refits the viewport.
    private void Arrange()
    {
        ComputeLayout();
        _shouldRender = true;
        _syncQueued = true;
        _fitQueued = true;
    }

    public async Task NudgeSelectedAsync(double dx, double dy)
    {
        if (SelectedNodeId is not { } id || !_positions.TryGetValue(id, out var pos)) return;
        var moved = (X: pos.X + dx, Y: pos.Y + dy);
        _positions[id] = moved;
        await CanvasJsAsync("codemap.canvas.moveNode", id, moved.X, moved.Y);
    }

    public async ValueTask DisposeAsync()
    {
        // _attached is only set after the first interactive render, so this skips the prerender
        // pass (where JS interop is unavailable and there is nothing to detach anyway).
        if (_attached)
        {
            try { await JS.InvokeVoidAsync("codemap.canvas.detach"); }
            catch (JSDisconnectedException) { /* circuit gone */ }
            catch (InvalidOperationException) { /* renderer torn down before interop */ }
        }
        _selfRef?.Dispose();
    }
}
